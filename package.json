{
  "name": "lsp-log-parser",
  "version": "1.0.0",
  "description": "Parser for LSP server logs",
  "author": "Rafał Chłodnicki",
  "private": true,
  "scripts": {
    "prepare": "nuxi prepare",
    "dev": "nuxi dev",
    "build": "nuxi build",
    "start": "nuxi preview",
    "generate": "nuxi generate",
    "lint": "yarn jslint && yarn csslint",
    "jslint": "eslint --ext .js,.ts,.vue --ignore-path .gitignore .",
    "csslint": "stylelint '**/*.scss' '**/*.vue'",
    "typecheck": "npx tsc"
  },
  "lint-staged": {
    "*.{js,ts,vue}": "eslint --ext .js,.ts,.vue --ignore-path .gitignore",
    "*.{scss,vue}": "stylelint"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged && yarn typecheck"
    }
  },
  "dependencies": {
    "@vueuse/core": "^11.3.0",
    "@vueuse/nuxt": "^11.3.0",
    "nuxt": "^3.20.1",
    "vue-json-pretty": "^2.6.0",
    "vuetify": "^3.10.11"
  },
  "devDependencies": {
    "@mdi/font": "^7.4.47",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/stylelint-module": "^5.2.1",
    "@types/node": "^20.19.25",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "eslint-plugin-vuetify": "^2.5.3",
    "husky": "^4.3.8",
    "lint-staged": "^15.5.2",
    "postcss": "^8.5.6",
    "postcss-html": "^1.8.0",
    "sass": "^1.94.0",
    "stylelint": "^15.11.0",
    "stylelint-config-recommended-scss": "^14.1.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^32.0.0",
    "typescript": "^5.9.3",
    "vite-plugin-vuetify": "^2.1.2",
    "vscode-languageserver-protocol": "^3.17.5"
  }
}
